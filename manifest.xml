<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xsi:type="TaskPaneApp">

  <!-- Identity -->
  <Id>a7b3c1d2-e4f5-6a89-bcde-f01234567890</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Avalie</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Avalie Team Icon Vault" />
  <Description DefaultValue="Search and insert SVG icons from 7 icon libraries directly onto your PowerPoint slides." />

  <!-- Icons -->
  <IconUrl DefaultValue="https://localhost:3000/assets/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://localhost:3000/assets/icon-64.png" />

  <SupportUrl DefaultValue="https://avalie.com" />

  <!-- PowerPoint only -->
  <Hosts>
    <Host Name="Presentation" />
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="PowerPointApi" MinVersion="1.1" />
    </Sets>
  </Requirements>

  <!-- Task pane source -->
  <DefaultSettings>
    <SourceLocation DefaultValue="https://localhost:3000/taskpane.html" />
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

  <!-- Ribbon Commands -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
                    xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Presentation">
        <DesktopFormFactor>
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <CustomTab id="AvalieTab">
              <Group id="AvalieIconGroup">
                <Label resid="GroupLabel" />
                <Icon>
                  <bt:Image size="16" resid="Icon16" />
                  <bt:Image size="32" resid="Icon32" />
                  <bt:Image size="80" resid="Icon80" />
                </Icon>
                <Control xsi:type="Button" id="ShowIconVault">
                  <Label resid="BtnLabel" />
                  <Supertip>
                    <Title resid="BtnLabel" />
                    <Description resid="BtnDesc" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon16" />
                    <bt:Image size="32" resid="Icon32" />
                    <bt:Image size="80" resid="Icon80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>AvalieIconVaultPane</TaskpaneId>
                    <SourceLocation resid="TaskpaneUrl" />
                  </Action>
                </Control>
              </Group>
              <Label resid="TabLabel" />
            </CustomTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon16" DefaultValue="https://localhost:3000/assets/icon-16.png" />
        <bt:Image id="Icon32" DefaultValue="https://localhost:3000/assets/icon-32.png" />
        <bt:Image id="Icon80" DefaultValue="https://localhost:3000/assets/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="TaskpaneUrl" DefaultValue="https://localhost:3000/taskpane.html" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="TabLabel" DefaultValue="Avalie Icons" />
        <bt:String id="GroupLabel" DefaultValue="Icon Vault" />
        <bt:String id="BtnLabel" DefaultValue="Icon Vault" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="BtnDesc" DefaultValue="Search and insert icons from 7 icon libraries onto your slides." />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
