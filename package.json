    "@iconify-json/heroicons": "^1.2.0",
    "@iconify-json/ri": "^1.2.0",
    "@iconify-json/fa6-regular": "^1.2.0",
    "@iconify-json/fa6-solid": "^1.2.0"
  },
  "devDependencies": {
    "@types/office-js": "^1.0.0",
    "copy-webpack-plugin": "^12.0.0",
    "css-loader": "^7.0.0",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.4.0",
