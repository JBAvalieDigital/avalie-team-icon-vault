{
  "compilerOptions": {
    "module": "es2020",
    "target": "ES2020",
    "outDir": "dist",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
